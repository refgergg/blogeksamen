<div class="min-h-screen bg-gradient-to-b from-gray-50 to-gray-100 py-12">
  <div class="max-w-4xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-5xl font-extrabold text-gray-900 mb-4">
        My Blog
      </h1>

      <p class="text-lg text-gray-600">
        Thoughts, tutorials, and updates
      </p>
    </div>

    <!-- Blog Posts -->
    <div class="space-y-8">
      <% @blog_posts.each do |blog_post| %>

        <div class="bg-white shadow-md rounded-2xl p-8 hover:shadow-xl transition duration-300 border border-gray-100">

          <!-- Status Badge -->
          <div class="mb-4">
            <% if blog_post.draft? %>
              <span class="inline-block px-3 py-1 text-sm font-semibold bg-yellow-100 text-yellow-800 rounded-full">
                Draft
              </span>

            <% elsif blog_post.scheduled? %>
              <span class="inline-block px-3 py-1 text-sm font-semibold bg-blue-100 text-blue-800 rounded-full">
                Scheduled
              </span>
            <% end %>
          </div>

          <!-- Title -->
          <h2 class="text-3xl font-bold mb-4">
            <%= link_to blog_post.title, blog_post,
              class: "text-gray-900 hover:text-indigo-600 transition duration-200" %>
          </h2>

          <!-- Body Preview -->
          <p class="text-gray-700 leading-relaxed text-lg">
            <%= truncate(blog_post.body, length: 220) %>
          </p>

          <!-- Read More -->
          <div class="mt-6">
            <%= link_to "Read more →", blog_post,
              class: "inline-flex items-center text-indigo-600 font-semibold hover:text-indigo-800 transition" %>
          </div>

        </div>

      <% end %>
    </div>

  </div>
</div>